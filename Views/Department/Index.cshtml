@model IEnumerable<EmployeeManagementSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Departments</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add Department</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No departments found. Add your first one!</div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Department Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model)
                {
                    <tr>
                        <td>@dept.Id</td>
                        <td>@dept.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@dept.Id"
                               class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@dept.Id"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>