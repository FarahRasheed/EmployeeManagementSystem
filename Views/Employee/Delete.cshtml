@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4>Delete Employee</h4>
                </div>
                <div class="card-body">
                    <p class="fs-5">Are you sure you want to delete:</p>
                    <p class="fw-bold fs-4 text-danger">@Model.FullName</p>
                    <p>Department: @Model.Department?.Name</p>
                    <p>Email: @Model.Email</p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Yes, Delete</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>